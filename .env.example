# Servers
APP_NAME="MyAppName"
PORT=8000
NODE_ENV=development
DATABASE_URL="POSTGRESQL CONNECTION STRING - Replace it here (Neon.com)"
BACKEND_URL="http://localhost:8000"

# JWT: Generate yours at https://jwtsecrets.com/
JWT_SECRET=

# FRONTEND
